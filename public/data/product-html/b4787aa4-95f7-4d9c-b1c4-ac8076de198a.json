tributorcentral.com/uploads/5/3/53EA9E75BAB40DA072BEE63D84C3E589.jpg\" alt=\"\" class=\"max-h-28 max-w-[180px] rounded border border-neutral-200 object-contain\" loading=\"lazy\" /></div><p class=\"font-semibold text-neutral-900\">ATT-1</p><p class=\"text-[12px] text-neutral-600\">J-Hook</p></div></div>\n</details>\n<details class=\"group border-b border-neutral-200 last:border-b-0 open:bg-neutral-50/50\">\n<summary class=\"cursor-pointer list-none py-3 pl-1 pr-2 text-[13px] font-semibold text-neutral-900 outline-none [&::-webkit-details-marker]:hidden\">\n<span class=\"flex items-start justify-between gap-3\">\n<span>Additional Imprint Color - Lanyards</span>\n<span class=\"mt-0.5 shrink-0 text-[10px] font-normal text-neutral-400 transition group-open:rotate-180\" aria-hidden=\"true\">▼</span>\n</span>\n</summary>\n<div class=\"border-t border-neutral-100 bg-white px-1 pb-3 pt-2\"><p class=\"mb-3 text-[13px] leading-relaxed text-neutral-700\">Please note that Setup charge and Run charges are applicable for additional colors.</p><p class=\"text-[13px] text-neutral-700\">Addtl Color Lanyards - General</p></div>\n</details>\n<details class=\"group border-b border-neutral-200 last:border-b-0 open:bg-neutral-50/50\">\n<summary class=\"cursor-pointer list-none py-3 pl-1 pr-2 text-[13px] font-semibold text-neutral-900 outline-none [&::-webkit-details-marker]:hidden\">\n<span class=\"flex items-start justify-between gap-3\">\n<span>2nd side imprint - Lanyards</span>\n<span class=\"mt-0.5 shrink-0 text-[10px] font-normal text-neutral-400 transition group-open:rotate-180\" aria-hidden=\"true\">▼</span>\n</span>\n</summary>\n<div class=\"border-t border-neutral-100 bg-white px-1 pb-3 pt-2\"><p class=\"mb-3 text-[13px] leading-relaxed text-neutral-700\">Please note that this charge is applicable per color/per lanyard.</p><p class=\"text-[12px] text-neutral-500\">No line choices listed—contact the studio for this add-on.</p></div>\n</details>\n<details class=\"group border-b border-neutral-200 last:border-b-0 open:bg-neutral-50/50\">\n<summary class=\"cursor-pointer list-none py-3 pl-1 pr-2 text-[13px] font-semibold text-neutral-900 outline-none [&::-webkit-details-marker]:hidden\">\n<span class=\"flex items-start justify-between gap-3\">\n<span>Premium Attachments - Lanyards</span>\n<span class=\"mt-0.5 shrink-0 text-[10px] font-normal text-neutral-400 transition group-open:rotate-180\" aria-hidden=\"true\">▼</span>\n</span>\n</summary>\n<div class=\"border-t border-neutral-100 bg-white px-1 pb-3 pt-2\"><div class=\"border-b border-neutral-100 py-3 last:border-0\"><div class=\"mb-2\"><img src=\"https://s3.distributorcentral.com/uploads/E/D/ED109E05871F3C8D035BBAE65060D6F3.jpg\" alt=\"\" class=\"max-h-28 max-w-[180px] rounded border border-neutral-200 object-contain\" loading=\"lazy\" /></div><p class=\"font-semibold text-neutral-900\">BA-1 or BA-2</p><p class=\"text-[12px] text-neutral-600\">Breakaway (1&quot; &amp; 3/4&quot;)</p><p class=\"mt-1 text-[13px] leading-relaxed text-neutral-700\">The style of Breakaway (BA-1 or BA-2)* are dependent upon the size. \n\n*Breakaway releases sold for lanyards are not sold as safety equipment, nor are they intended for such purpose.</p><p class=\"mt-1 text-[12px] font-medium text-neutral-800\">$0.27 each</p></div><div class=\"border-b border-neutral-100 py-3 last:border-0\"><div class=\"mb-2\"><img src=\"https://s3.distributorcentral.com/uploads/8/9/89E4EA374BE953CF4828A30717861088.jpg\" alt=\"\" class=\"max-h-28 max-w-[180px] rounded border border-neutral-200 object-contain\" loading=\"lazy\" /></div><p class=\"font-semibold text-neutral-900\">2nd Attachment</p><p class=\"mt-1 text-[13px] leading-relaxed text-neutral-700\">This is to add a second attachment to the lanyard. For instance, if you require a J-hook &amp; Split Ring on the lanyard. \n\nThe charge is only applicable to the second attachment.</p><p class=\"mt-1 text-[12px] font-medium text-neutral-800\">$0.13 each</p></div><div class=\"border-b border-neutral-100 py-3 last:border-0\"><div class=\"mb-2\"><img src=\"https://s3.distributorcentral.com/uploads/1/F/1F1B6AE25757FC1CAF5D9EF674F45E34.jpg\" alt=\"\" class=\"max-h-28 max-w-[180px] rounded border border-neutral-200 object-contain\" loading=\"lazy\" /></div><p class=\"font-semibold text-neutral-900\">ATT-10</p><p class=\"text-[12px] text-neutral-600\">Quick Release (1&quot; &amp; 3/4&quot;)</p><p class=\"mt-1 text-[12px] font-medium text-neutral-800\">$0.27 each</p></div><div class=\"border-b border-neutral-100 py-3 last:border-0\"><div class=\"mb-2\"><img src=\"https://s3.distributorcentral.com/uploads/5/F/5F1288E5F6668A641D01E64A8DFF13C9.jpg\" alt=\"\" class=\"max-h-28 max-w-[180px] rounded border border-neutral-200 object-contain\" loading=\"lazy\" /></div><p class=\"font-semibold text-neutral-900\">Adjustable Clips</p><p class=\"mt-1 text-[12px] font-medium text-neutral-800\">$0.22 each</p></div></div>\n</details>\n<details class=\"group border-b border-neutral-200 last:border-b-0 open:bg-neutral-50/50\">\n<summary class=\"cursor-pointer list-none py-3 pl-1 pr-2 text-[13px] font-semibold text-neutral-900 outline-none [&::-webkit-details-marker]:hidden\">\n<span class=\"flex items-start justify-between gap-3\">\n<span>Metallic Imprint - Lanyard</span>\n<span class=\"mt-0.5 shrink-0 text-[10px] font-normal text-neutral-400 transition group-open:rotate-180\" aria-hidden=\"true\">▼</span>\n</span>\n</summary>\n<div class=\"border-t border-neutral-100 bg-white px-1 pb-3 pt-2\"><p class=\"mb-3 text-[13px] leading-relaxed text-neutral-700\">Additional Run charge of $0.10(R)\r\n\r\nPMS Metallic Colors: 871C and 877C</p><p class=\"text-[12px] text-neutral-500\">No line choices listed—contact the studio for this add-on.</p></div>\n</details>\n</div>\n</div>\n\n<p class=\"text-[12px] text-neutral-500 mt-4\">Final quote may reflect selected options, proofs, rush, or freight beyond list pricing.</p>\n</div>","salesToolsHtml":"<div class=\"space-y-4 text-[13px] leading-relaxed text-neutral-800\">\n<p><strong class=\"text-neutral-900\">Pitch this SKU</strong> — 5/8&quot; Pricebuster Flat Polyester Lanyard. Lead with use case (uniforms, retail, teams, recognition), then minimums and timeline. Reference included services from “Price includes” in the Description tab when present (e.g. setup, virtual proof, shipping offers).</p>\n<ul class=\"list-disc pl-5 space-y-2\">\n<li>Quote style <span class=\"font-mono text-neutral-900\">PB-58</span> on proposals and POs.</li>\n<li>Offer virtual proofs and artwork checks before production.</li>\n<li>Cross-sell with hats, bags, or jackets for kit programs.</li>\n<li>For decoration and imprint methods, follow supplier notes in the Description tab.</li>\n</ul>\n<p class=\"text-[12px] text-neutral-500\">Approved partners can request internal sell sheets, comparison matrices, and margin guidance from the A Design Line team.</p>\n</div>","inventoryHtml":"<div class=\"space-y-3 text-[13px] leading-relaxed text-neutral-800\">\n<p>Merchandise is <strong class=\"text-neutral-900\">typically sourced to order</strong>. Stock and availability may vary by supplier and season.</p>\n<p>Supplier-stated production window: <strong>10 days</strong> (not including transit).</p>\n<p>Contact the studio for <strong>rush</strong> feasibility, <strong>split shipments</strong>, or <strong>multi-location</strong> drops before placing large orders.</p>\n<p class=\"text-[12px] text-neutral-500\">Minimum order quantity: <strong class=\"text-neutral-800\">100</strong> units (per catalog line).</p>\n</div>"}