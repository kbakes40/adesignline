# Site
SITE_NAME=A Design Line

# Supabase catalog (optional — leave off to use in-memory catalog from lib/adesignline-data)
NEXT_PUBLIC_SUPABASE_URL=https://shdsbsxmdvvrwaurshod.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Set to 1 only after running `pnpm sync:supabase` and applying supabase/migrations/001_product_catalog.sql
NEXT_PUBLIC_SUPABASE_CATALOG=0

# Server-only: sync script, Storage uploads, signed URLs for private artwork
SUPABASE_SERVICE_ROLE_KEY=

# Storage buckets (create in Supabase Dashboard): product-images, product-thumbs, brand-assets, hero-banners (public); artwork-uploads (private)
# Optional: signed URL lifetime for private artwork previews (seconds, 60–604800)
# ARTWORK_SIGNED_URL_TTL_SECONDS=3600

# Optional upload size caps (bytes). Server may use MAX_ARTWORK_UPLOAD_BYTES; client uses NEXT_PUBLIC_MAX_ARTWORK_BYTES.
# NEXT_PUBLIC_MAX_ARTWORK_BYTES=10485760
# MAX_ARTWORK_UPLOAD_BYTES=10485760

# Google Analytics 4 — server-only (Traffic Intelligence at /backend/traffic)
# Service account needs Viewer on the GA4 property.
# GA4_PROPERTY_ID=
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=
